rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdventureEntry(data) {
      return data.keys().hasOnly([
          'type',
          'sourceId',
          'title',
          'deltaYen',
          'balanceBeforeYen',
          'balanceAfterYen',
          'occurredAtUtc',
          'createdAtUtc',
          'isLegacyEstimate',
          'note'
        ]) &&
        data.type in [
          'taskCompleted',
          'taskReverted',
          'wishPurchased',
          'wishUnpurchased',
          'healthAdjusted',
          'manualAdjusted'
        ] &&
        data.title is string &&
        data.deltaYen is number &&
        data.balanceBeforeYen is number &&
        data.balanceAfterYen is number &&
        data.occurredAtUtc is timestamp &&
        data.createdAtUtc is timestamp;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /adventure_entries/{entryId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isAdventureEntry(request.resource.data);
        allow update, delete: if false;
      }

      match /tasks/{taskId} {
        allow read, write: if isOwner(userId);
      }

      match /wishlist/{itemId} {
        allow read, write: if isOwner(userId);
      }

      match /healthLogs/{logId} {
        allow read, write: if isOwner(userId);
      }

      // ストリーク状態（doc id 固定 'streak'）。非現金（称号＋フリーズのみ）。
      // サブコレクションのルールは親から継承されないため明示する。
      match /healthState/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /daily_earnings/{day} {
        allow read, write: if isOwner(userId);
      }

      // 「1日通しセット」の日次状態（サイクル位置・やりかけ作業フェーズ・
      // 未消化休憩）。本人のみ。
      match /pomodoro_days/{dateKey} {
        allow read, write: if isOwner(userId);
      }

      // ご褒美チケット在庫（ルーレット報酬）。本人のみ。
      // サブコレクションのルールは親から継承されないため明示する。
      // 消費は used=true への update を許可する（台帳と異なり更新可）。
      match /reward_tickets/{ticketId} {
        allow read, write: if isOwner(userId);
      }

      match /settings/{settingId} {
        allow read, write: if isOwner(userId);
      }

      // 計測中タイマー（単一ドキュメント固定 = 同時1タイマー保証）。本人のみ。
      match /active_timer/{docId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
